# 법제처 오픈API 인증키 (필수)
# 발급: https://www.law.go.kr/DRF/lawService.do
LAW_OC=your-api-key-here

# (선택) ALIO 수집 데이터 저장 경로 override
# 기본값: <package_root>/data/alio/
# ALIO_DATA_DIR=/path/to/alio/data

# (선택) ALIO 자연어 라우팅용 기관 약어 매핑 (JSON object)
# 자연어로 "<약어> 규정 비교" 같이 입력 시 인식하려면 등록 필요
# 미설정 시 자연어 라우팅은 'C0xxx' apbaId 코드와 일반 키워드(공공기관/ALIO 등)만 동작
# ALIO_INSTITUTION_ALIASES={"MYORG":"우리기관","ACME":"에이씨엠이"}

# (선택) docling OCR fallback 설정 — `npm run alio:sync -- --docling-fallback` 시 사용
# docling CLI 가 PATH 에 없거나 다른 환경이면 경로 override 가능
# DOCLING_BIN=/opt/homebrew/bin/docling
# DOCLING_OCR_ENGINE=tesseract  # tesseract(기본)|easyocr|ocrmac|rapidocr
# DOCLING_OCR_LANG=kor+eng      # tesseract: kor+eng / easyocr: ko,en / ocrmac: ko-KR,en-US
# DOCLING_DEVICE=auto           # auto|cpu|cuda|mps — Apple Silicon 이면 mps 권장
# DOCLING_TIMEOUT_MS=600000
